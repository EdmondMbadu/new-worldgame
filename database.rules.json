{
  "rules": {
    ".read": false,
    ".write": false,
    "status": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['state', 'lastChanged'])",
        "state": {
          ".validate": "newData.val() == 'online' || newData.val() == 'offline'"
        },
        "lastChanged": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
