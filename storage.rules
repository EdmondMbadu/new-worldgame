rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isVideoUpload() {
      return request.resource != null
        && request.resource.size < 2 * 1024 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    match /nwgNewsVideos/videos/{year}/{fileName} {
      allow read: if true;
      allow create, update: if signedIn() && isVideoUpload();
      allow delete: if signedIn();
    }

    match /{topLevel}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && topLevel != 'nwgNewsVideos';
    }
  }
}
